# SQLite is the default and requires no external service.
DATABASE_URL=sqlite:///./storyforge.db

# PostgreSQL is optional. Supply credentials through your local .env or process environment.
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/storyforge

# Milestone 2 LLM provider. Never commit a real key.
OPENAI_API_KEY=replace-with-your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=replace-with-a-structured-output-capable-model
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_REPAIR_RETRIES=1
LLM_RETRY_BASE_DELAY_SECONDS=0.5
