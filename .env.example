# Safe local defaults. Copy to .env only for your own tooling; StoryForge does not load it implicitly.
STORYFORGE_ENVIRONMENT=development
STORYFORGE_DATABASE_URL=sqlite:///./storyforge.db
STORYFORGE_LLM_PROVIDER=mock
STORYFORGE_LLM_MODEL=mock-storyforge-v1
STORYFORGE_LLM_BASE_URL=https://api.openai.com/v1
STORYFORGE_LLM_API_KEY=
STORYFORGE_LLM_TIMEOUT_SECONDS=30
STORYFORGE_LLM_MAX_RETRIES=2
STORYFORGE_LLM_REPAIR_RETRIES=1
STORYFORGE_LLM_RETRY_BASE_DELAY_SECONDS=0.5
STORYFORGE_EMBEDDING_PROVIDER=mock
STORYFORGE_EMBEDDING_MODEL=mock-hash-embedding-v1
STORYFORGE_EMBEDDING_BASE_URL=https://api.openai.com/v1
STORYFORGE_EMBEDDING_API_KEY=
STORYFORGE_EMBEDDING_DIMENSIONS=64
STORYFORGE_EMBEDDING_BATCH_SIZE=32
STORYFORGE_EMBEDDING_TIMEOUT=30
STORYFORGE_EMBEDDING_MAX_RETRIES=2
STORYFORGE_VECTOR_DISTANCE=cosine
STORYFORGE_RETRIEVAL_TOP_K=20
STORYFORGE_RETRIEVAL_MAX_TOP_K=100
STORYFORGE_RETRIEVAL_MAX_CONTEXT_CHARS=16000
STORYFORGE_HYBRID_KEYWORD_WEIGHT=0.20
STORYFORGE_HYBRID_VECTOR_WEIGHT=0.35
STORYFORGE_HYBRID_FACT_WEIGHT=0.25
STORYFORGE_HYBRID_GRAPH_WEIGHT=0.20
STORYFORGE_RETRIEVAL_DEBUG=false
STORYFORGE_MOCK_WORKFLOW_SCENARIO=improve
STORYFORGE_MOCK_CRITIC_SCENARIO=normal
STORYFORGE_MOCK_MODE=true
STORYFORGE_AUTO_MIGRATE=false
STORYFORGE_API_HOST=127.0.0.1
STORYFORGE_API_PORT=8000
STORYFORGE_WEB_PORT=3000
STORYFORGE_LOG_LEVEL=INFO
STORYFORGE_LOG_FORMAT=text
STORYFORGE_ALLOWED_ORIGINS=
STORYFORGE_CORS_ALLOW_CREDENTIALS=false
STORYFORGE_API_PREFIX=/api/v1
STORYFORGE_DEFAULT_PAGE_SIZE=20
STORYFORGE_MAXIMUM_PAGE_SIZE=100
STORYFORGE_MAX_REVISION_ATTEMPTS=3
STORYFORGE_ALLOW_DEBUG_PAUSE_NODES=false
STORYFORGE_INCLUDE_ERROR_DETAIL_IN_LOGS=false
STORYFORGE_REQUEST_BODY_LIMIT=1048576
STORYFORGE_MAX_CHAPTER_CONTENT_CHARS=500000
STORYFORGE_MAX_DIFF_CHARS=50000
STORYFORGE_CHECKPOINT_PATH=
STORYFORGE_ENABLE_HTTP_LOGGING=true
STORYFORGE_DATABASE_WAIT_ATTEMPTS=30
STORYFORGE_DATABASE_WAIT_INTERVAL_SECONDS=1

# Alembic reads DATABASE_URL directly so migration commands can target a separate database.
DATABASE_URL=sqlite:///./storyforge.db

# Production example (never commit a real credential):
# STORYFORGE_ENVIRONMENT=production
# STORYFORGE_LLM_PROVIDER=openai-compatible
# STORYFORGE_LLM_MODEL=replace-with-a-structured-output-capable-model
# STORYFORGE_LLM_API_KEY=replace-with-your-api-key
# STORYFORGE_EMBEDDING_PROVIDER=openai-compatible
# STORYFORGE_EMBEDDING_MODEL=replace-with-an-embedding-model
# STORYFORGE_EMBEDDING_API_KEY=replace-with-your-embedding-api-key
# STORYFORGE_DATABASE_URL=postgresql+psycopg://user:percent-encoded-password@db:5432/storyforge
# STORYFORGE_MOCK_MODE=false
